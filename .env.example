# Required in production: generate with `secrets.token_urlsafe(32)`.
SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=production
SESSION_COOKIE_SECURE=true
SESSION_LIFETIME_MINUTES=60
LOG_LEVEL=INFO
# Optional: keep SQLite data outside the deployed code directory.
# DATABASE_PATH=/var/lib/smart-library/library.db
