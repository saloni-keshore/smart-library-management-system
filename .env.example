# Required in production: generate with `secrets.token_urlsafe(32)`.
SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=production
SESSION_COOKIE_SECURE=true
SESSION_LIFETIME_MINUTES=60
LOG_LEVEL=INFO
# Optional: keep SQLite data outside the deployed code directory.
# DATABASE_PATH=/var/lib/smart-library/library.db
# Required by routes/auth.py (database/supabase_client.py) — the admins table
# now lives in Supabase, not SQLite. Other modules still use SQLite above.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=replace-with-your-supabase-service-role-key
