# Python bytecode / cache
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Test coverage
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Environment variables / secrets
.env

# SQLite data is operational data; keep it out of source control.
database/*.db
backups/*.db
*.db-journal
*.db-wal
*.db-shm
instance/

# Runtime uploads can contain customer-provided documents.
static/uploads/settings/*
!static/uploads/settings/.gitkeep

# OS cruft
.DS_Store
Thumbs.db

# Editor/IDE
.idea/
.vscode/
